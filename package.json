{
  "name": "openbookmap",
  "version": "0.2.0",
  "private": true,
  "description": "A global, open map of used bookstores, with searchable inventories from shelf photos. Built on OpenStreetMap.",
  "license": "MIT",
  "homepage": "https://openbookmap.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/tautme/openbookmap.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "format": "prettier --write \"src/**/*.{js,css}\" \"tests/**/*.js\" \"*.html\"",
    "format:check": "prettier --check \"src/**/*.{js,css}\" \"tests/**/*.js\" \"*.html\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "browser-image-compression": "^2.0.2",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "tesseract.js": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "eslint": "^9.10.0",
    "globals": "^15.9.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.3",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
